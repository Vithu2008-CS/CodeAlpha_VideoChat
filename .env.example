# Copy this file to `.env` and adjust as needed.

# Database connection strings (Supabase PostgreSQL configuration)
DATABASE_URL="postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Secret used to sign JWTs — set a long random string in production.
JWT_SECRET="change-this-to-a-long-random-secret"

# How long issued tokens stay valid.
JWT_EXPIRES_IN="7d"

# HTTP port for the Express + Socket.io server.
PORT=3000

# Signaling WebSocket server URL (leave blank to use the local same-origin server,
# or set to your external signaling server URL like https://your-signaling.railway.app in Vercel serverless production).
SIGNALING_SERVER_URL=""
